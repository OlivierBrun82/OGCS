<form method="post" action="{{ path('app_abscences_delete', {'id': abscence.id}) }}" onsubmit="return confirm('Supprimer cette absence ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ abscence.id) }}">
    <button type="submit" class="btn btn-outline-danger btn-sm">Supprimer</button>
</form>
