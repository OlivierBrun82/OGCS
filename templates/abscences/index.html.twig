{% extends 'base.html.twig' %}

{% block title %}Absences{% endblock %}

{% block body %}
    <h1>Absences des joueurs</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Joueur</th>
                <th>Motif</th>
                <th>Du</th>
                <th>Au</th>
                <th>Enregistré par</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for abscence in abscences %}
            <tr>
                <td>
                    {% if abscence.players %}
                        {{ abscence.players.firstName }} {{ abscence.players.lastName }}
                    {% else %}
                        —
                    {% endif %}
                </td>
                <td>{{ abscence.motive }}</td>
                <td>{{ abscence.absenceStart|date('d/m/Y') }}</td>
                <td>{{ abscence.absenceEnd|date('d/m/Y') }}</td>
                <td>{{ abscence.user ? abscence.user.email : '—' }}</td>
                <td>
                    <a href="{{ path('app_abscences_show', {'id': abscence.id}) }}">Voir</a>
                    {% if abscence.user and app.user and abscence.user.id == app.user.id %}
                        <a href="{{ path('app_abscences_edit', {'id': abscence.id}) }}">Modifier</a>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">Aucune absence enregistrée</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_abscences_new') }}">Ajouter une absence</a>
{% endblock %}
