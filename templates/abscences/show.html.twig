{% extends 'base.html.twig' %}

{% block title %}Absence{% endblock %}

{% block body %}
    <h1>Absence</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Joueur</th>
                <td>
                    {% if abscence.players %}
                        {{ abscence.players.firstName }} {{ abscence.players.lastName }}
                    {% else %}
                        —
                    {% endif %}
                </td>
            </tr>
            <tr>
                <th>Motif</th>
                <td>{{ abscence.motive }}</td>
            </tr>
            <tr>
                <th>Période</th>
                <td>du {{ abscence.absenceStart|date('d/m/Y') }} au {{ abscence.absenceEnd|date('d/m/Y') }}</td>
            </tr>
            <tr>
                <th>Enregistré par</th>
                <td>{{ abscence.user ? abscence.user.email : '—' }}</td>
            </tr>
            <tr>
                <th>Enregistré le</th>
                <td>{{ abscence.createdAt ? abscence.createdAt|date('d/m/Y H:i') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <p>
        <a href="{{ path('app_abscences_index') }}">Retour à la liste</a>
        {% if abscence.players %}
            —
            <a href="{{ path('player_show', {'id': abscence.players.id}) }}">Fiche joueur</a>
        {% endif %}
    </p>

    {% if abscence.user and app.user and abscence.user.id == app.user.id %}
        <a href="{{ path('app_abscences_edit', {'id': abscence.id}) }}">Modifier</a>

        {{ include('abscences/_delete_form.html.twig') }}
    {% endif %}
{% endblock %}
