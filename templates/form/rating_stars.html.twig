{% block rating_stars_widget %}
<div
    class="star-rating-field"
    {{ stimulus_controller('star-rating') }}
    role="radiogroup"
    aria-label="{{ 'Choisissez une note de 1 à 10'|trans }}"
    data-star-rating-value="">
    <input type="hidden"
        data-star-rating-target="input"
        value="{{ value }}"
        {{ block('widget_attributes') }} />
    <div class="star-rating-field__stars">
        {% for i in 1..10 %}
            <button type="button"
                class="star-rating-field__star"
                role="radio"
                data-star-rating-target="starBtn"
                aria-checked="false"
                data-action="click->star-rating#choose mouseenter->star-rating#preview mouseleave->star-rating#clearPreview"
                data-value="{{ i }}">{{ '★' }}</button>
        {% endfor %}
    </div>
</div>
{% endblock %}
