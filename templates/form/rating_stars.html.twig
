{% block rating_stars_widget %}
{% set widget_value = form.vars.value %}
<div
    class="star-rating-field"
    {{ stimulus_controller('star-rating') }}
    role="radiogroup"
    aria-labelledby="{{ form.vars.label_attr.id|default(form.vars.id ~ '_lbl') }}"
    data-star-rating-value="">
    {% if label is defined and label is not same as(false) and form.vars.label_attr.id is not defined %}
        <span id="{{ form.vars.id ~ '_lbl' }}" class="star-rating-field__label">{{ form.vars.label }}</span>
    {% endif %}
    <input type="hidden"
        id="{{ form.vars.id }}"
        name="{{ form.vars.full_name }}"
        {% if widget_value %}{{ stimulus_target('star-rating', 'input').attribute('input') }}
        {# Symfony ne fournit pas stimulus_target ainsi — utilisons data attributes manuellement #}
    {% endif %}
    {{ block('widget_attributes') }}
/>

