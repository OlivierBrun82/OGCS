{{ form_start(form) }}
    {{ form_row(form.date) }}
    {{ form_row(form.type) }}
    {{ form_row(form.location) }}
    {{ form_row(form.homeTeam) }}
    {{ form_row(form.awayTeam) }}

    {% set compositions_count = form.compositions|length %}
    <div class="composition-collection-shell" {{ stimulus_controller('match-composition-collection', { nextIndex: compositions_count }) }}>
        {{ form_label(form.compositions) }}
        {{ form_help(form.compositions) }}
        {{ form_errors(form.compositions) }}
        {{ form_widget(form.compositions, {
            attr: { 'data-match-composition-collection-target': 'holder' },
        }) }}
        <button type="button"
            class="btn btn-outline-secondary btn-sm mb-3"
            data-action="click->match-composition-collection#add">
            Ajouter un joueur à la composition
        </button>
    </div>

    <button class="btn btn-primary">{{ button_label|default('Enregistrer') }}</button>
{{ form_end(form) }}
