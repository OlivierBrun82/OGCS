{% extends 'base.html.twig' %}

{% block title %}Matchs{% endblock %}

{% block body %}
    <h1>Matchs</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Date</th>
                <th>Domicile</th>
                <th>Extérieur</th>
                <th>Type</th>
                <th>Lieu</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        {% for match in matches %}
            <tr>
                <td>{{ match.id }}</td>
                <td>{{ match.date ? match.date|date('Y-m-d') : '' }}</td>
                <td>{{ match.homeTeam ? match.homeTeam.teamName : '—' }}</td>
                <td>{{ match.awayTeam ? match.awayTeam.teamName : '—' }}</td>
                <td>{{ match.type }}</td>
                <td>{{ match.location }}</td>
                <td>
                    <a href="{{ path('app_matches_show', {'id': match.id}) }}">voir</a>
                    <a href="{{ path('app_matches_edit', {'id': match.id}) }}">modifier</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7">Aucun match</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <p class="page-toolbar"><a href="{{ path('app_matches_new') }}" class="btn btn-primary">Nouveau match</a></p>
{% endblock %}
