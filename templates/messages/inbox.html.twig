{% extends 'base.html.twig' %}

{% block title %}Messages — Réception{% endblock %}

{% block body %}
    <h1>Boîte de réception</h1>

    {{ include('messages/_nav.html.twig') }}

    <table class="table">
        <thead>
            <tr>
                <th>De</th>
                <th>Reçu le</th>
                <th>Lu</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for m in messages %}
            <tr>
                <td>{{ m.sender.email }}</td>
                <td>{{ m.sentAt|date('d/m/Y H:i', 'Europe/Paris') }}</td>
                <td>{{ m.readAt ? 'Oui (' ~ m.readAt|date('d/m/Y H:i', 'Europe/Paris') ~ ')' : 'Non' }}</td>
                <td><a href="{{ path('app_messages_show', {'id': m.id}) }}">Voir</a></td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">Aucun message reçu</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
