{% extends 'base.html.twig' %}

{% block title %}{{ players.firstName }} {{ players.lastName }}{% endblock %}

{% block body %}
    <h1>{{ players.firstName }} {{ players.lastName }}</h1>
    <p class="page-meta">Fiche joueur · maillot {% if players.number is not null %}#{{ players.number }}{% else %}non attribué{% endif %}</p>

    <section class="detail-panel" aria-label="Informations joueur">
        {% set photoUrl = vich_uploader_asset(players, 'photoFile') %}
        {% if photoUrl %}
            <figure class="player-photo player-photo--detail player-photo--in-panel" aria-label="Photo du joueur">
                <img
                    src="{{ asset(photoUrl) }}"
                    alt="Photo de {{ players.firstName }} {{ players.lastName }}"
                    width="320"
                    height="320"
                    loading="eager"
                    fetchpriority="high"
                    decoding="async"
                    class="player-photo__img"
                >
            </figure>
        {% endif %}
        <dl class="detail-list">
            <dt>Prénom</dt>
            <dd>{{ players.firstName }}</dd>
            <dt>Nom</dt>
            <dd>{{ players.lastName }}</dd>
            <dt>Statut</dt>
            <dd>{{ players.statut ? players.statut.value : '—' }}</dd>
            <dt>Email</dt>
            <dd>{{ players.email }}</dd>
            <dt>Date de naissance</dt>
            <dd>{{ players.birthdate ? players.birthdate|date('d/m/Y') : '—' }}</dd>
            <dt>Licence</dt>
            <dd>{{ players.licence ? players.licence|date('d/m/Y') : '—' }}</dd>
            <dt>Certificat médical</dt>
            <dd>{{ players.medicalCertificate ? players.medicalCertificate|date('d/m/Y') : '—' }}</dd>
            <dt>Catégorie</dt>
            <dd>{{ players.categorie ? players.categorie.value : '—' }}</dd>
            <dt>Équipe</dt>
            <dd>
                {% if players.teams %}
                    <a href="{{ path('team_show', { id: players.teams.id }) }}">{{ players.teams.teamName }}</a>
                {% else %}
                    —
                {% endif %}
            </dd>
        </dl>
    </section>

    <div class="page-toolbar page-toolbar--player-actions">
        <form method="get" action="{{ path('player_update', { id: players.id }) }}">
            <button type="submit" class="btn btn-primary">Modifier</button>
        </form>
        <form method="get" action="{{ path('app_abscences_new_for_player', { player: players.id }) }}">
            <button type="submit" class="btn btn-secondary">Ajouter une absence</button>
        </form>
    </div>

    <div class="page-toolbar page-toolbar--back">
        <a href="{{ path('players_index') }}">← Liste des joueurs</a>
    </div>
{% endblock %}
