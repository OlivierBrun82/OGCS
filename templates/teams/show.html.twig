{% extends 'base.html.twig' %}

{% block title %}{{ teams.teamName }}{% endblock %}

{% block body %}
    <h1>{{ teams.teamName }}</h1>
    <p class="page-meta">Fiche équipe</p>

    <section class="detail-panel" aria-label="Informations équipe">
        <dl class="detail-list">
            <dt>Nom de l’équipe</dt>
            <dd>{{ teams.teamName }}</dd>
            
            <dt>Effectif</dt>
            <dd>
                {% set count = teams.players|length %}
                {{ count }} joueur{{ count > 1 ? 's' : '' }}
                {% if count > 0 %}
                {% endif %}
            </dd>
            <dt>Joueurs</dt>
            {% for player in teams.players %}
                <span>{{ player.firstName }} <br> {{ player.lastName }} ({{ player.number }})</span> <br>
            {% endfor %}            
        </dl>
    </section>

    <div class="page-toolbar">
        <form method="get" action="{{ path('team_update', { id: teams.id }) }}">
            <button type="submit" class="btn btn-primary">Modifier</button>
        </form>
    </div>

    <div class="page-toolbar page-toolbar--back">
        <a href="{{ path('teams_index') }}">← Liste des équipes</a>
    </div>
{% endblock %}
