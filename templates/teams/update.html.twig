{% extends 'base.html.twig' %}

{% block title %}Modifier {{ teams.teamName }}{% endblock %}

{% block body %}
    <h1>Modifier l’équipe</h1>
    <p class="page-meta">{{ teams.teamName }}</p>

    <section class="detail-panel detail-panel--form" aria-label="Formulaire">
        {{ form(formTeam) }}
    </section>

    <p class="page-toolbar mt-3">
        <a href="{{ path('teams_index') }}" class="btn btn-secondary btn-sm">← Liste des équipes</a>
        <form method="get" action="{{ path('team_show', { id: teams.id }) }}">
            <button type="submit" class="btn btn-outline-secondary btn-sm">Voir la fiche</button>
        </form>
    </p>
{% endblock %}
